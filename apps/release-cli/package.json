{
    "name": "@axm-internal/release-cli",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "src/cli.ts",
    "description": "Version bumping, git tagging, npm publishing, and release orchestration",
    "scripts": {
        "dev": "bun src/cli.ts",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "check-types": "tsc --noEmit",
        "test": "bun test",
        "test:coverage": "bun test --coverage --coverage-reporter=lcov",
        "validate": "echo \"Validated\""
    },
    "dependencies": {
        "@axm-internal/cli-kit": "*",
        "@axm-internal/cli-tools": "*",
        "@axm-internal/config-schema": "*",
        "@axm-internal/git-db": "*",
        "execa": "^9.6.1",
        "yocto-spinner": "^1.0.0",
        "yoctocolors": "^2.1.2",
        "zod": "^4.3.5"
    },
    "devDependencies": {
        "@axm-internal/tooling-config": "*",
        "@types/bun": "^1.3",
        "typescript": "^5"
    }
}
